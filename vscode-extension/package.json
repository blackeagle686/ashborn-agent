{
  "name": "ashborn-agent",
  "displayName": "Ashborn Agent 🔥",
  "description": "AI-powered autonomous developer agent — powered by Phoenix AI",
  "version": "1.0.0",
  "publisher": "ashborn",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "ashborn-sidebar",
          "title": "Ashborn Agent",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ashborn-sidebar": [
        {
          "type": "webview",
          "id": "ashborn.chatView",
          "name": "Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "ashborn.sendMessage",
        "title": "Ashborn: Send Message",
        "icon": "$(send)"
      },
      {
        "command": "ashborn.runAgent",
        "title": "Ashborn: ▶ Run Agent (Auto Mode)"
      },
      {
        "command": "ashborn.stopAgent",
        "title": "Ashborn: ⏹ Stop Agent"
      },
      {
        "command": "ashborn.resetSession",
        "title": "Ashborn: 🔄 Reset Session"
      },
      {
        "command": "ashborn.startServer",
        "title": "Ashborn: Start Server"
      },
      {
        "command": "ashborn.action.explain",
        "title": "Ashborn: Explain Code"
      },
      {
        "command": "ashborn.action.refactor",
        "title": "Ashborn: Refactor Code"
      },
      {
        "command": "ashborn.action.optimize",
        "title": "Ashborn: Optimize Performance"
      },
      {
        "command": "ashborn.action.fix",
        "title": "Ashborn: Fix Bugs"
      }
    ],
    "submenus": [
      {
        "id": "ashborn.actions",
        "label": "Ashborn AI",
        "icon": "$(flame)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "ashborn.actions",
          "group": "navigation@99",
          "when": "editorHasSelection"
        }
      ],
      "ashborn.actions": [
        {
          "command": "ashborn.action.explain",
          "group": "1_actions@1"
        },
        {
          "command": "ashborn.action.refactor",
          "group": "1_actions@2"
        },
        {
          "command": "ashborn.action.optimize",
          "group": "1_actions@3"
        },
        {
          "command": "ashborn.action.fix",
          "group": "1_actions@4"
        }
      ]
    },
    "configuration": {
      "title": "Ashborn Agent",
      "properties": {
        "ashborn.serverPort": {
          "type": "number",
          "default": 8765,
          "description": "Port for the Ashborn agent server"
        },
        "ashborn.venvPath": {
          "type": "string",
          "default": "venv",
          "description": "Path to Python venv (relative to workspace root, or absolute)"
        },
        "ashborn.autoStartServer": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start the agent server when the extension activates"
        },
        "ashborn.defaultMode": {
          "type": "string",
          "enum": [
            "auto",
            "plan",
            "fast_ans"
          ],
          "default": "auto",
          "description": "Default agent execution mode"
        }
      }
    },
    "productIconThemes": [
      {
        "id": "ashborn-icons",
        "label": "Ashborn Icons",
        "path": "./media/ashborn-icons.json"
      }
    ],
    "keybindings": [
      {
        "command": "workbench.action.toggleSidebarVisibility",
        "key": "ctrl+b",
        "when": "!terminalFocus"
      },
      {
        "command": "workbench.action.togglePanel",
        "key": "ctrl+alt+i",
        "when": "!terminalFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "2.22.0",
    "typescript": "^5.3.0",
    "vsce": "^1.103.1"
  }
}
